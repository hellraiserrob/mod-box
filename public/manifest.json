{
  "manifest_version": 3,
  "name": "ModBox",
  "description": "Block requests, modify HTTP request & response headers globally or by domain and url rules, organise by project and environment",
  "version": "0.0.1",
  "author": {
    "email": "robertjamesphillips@googlemail.com"
  },
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "icons": {
    "16": "images/16_16.png",
    "32": "images/32_32.png",
    "48": "images/48_48.png",
    "128": "images/128_128.png"
  }
}